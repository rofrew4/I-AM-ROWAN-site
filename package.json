{
  "name": "i-am-rowan",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash scripts/dev-fresh.sh",
    "dev:webpack": "bash scripts/dev-fresh.sh --webpack",
    "dev:turbo": "bash scripts/dev-fresh.sh",
    "clean": "rm -rf .next .next-build",
    "optimize-images": "node scripts/optimize-images.mjs",
    "prebuild": "npm run optimize-images",
    "build": "NEXT_DIST_DIR=.next-build next build",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && next lint",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.49",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
